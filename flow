# ==============================================================================
# SAFE CURSES WRITE — clips at boundaries, never crashes
# ==============================================================================
def saddstr(win, y, x, text, attr=0):
    try:
        my, mx = win.getmaxyx()
        if y < 0 or y >= my or x >= mx:
            return
        avail = mx - x - 1
        if avail <= 0:
            return
        win.addstr(y, x, text[:avail], attr)
    except curses.error:
        pass


