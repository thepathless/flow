# Source-distribution contents for `pip`/`python -m build`.
# The script and license are the essentials; docs help on PyPI.
include flow
include LICENSE
include README.md
include install.sh

# Bundled Krishna-flute recording (optional ambient track). It is NOT installed
# by pip into a runtime location — flow only copies it when it sits next to the
# script. Shipping it in the sdist keeps the tarball self-contained.
include krishna-*.mp3

# Never ship build/dev cruft.
global-exclude __pycache__ *.py[cod] *-ls.txt
prune tools
